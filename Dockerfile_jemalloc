ARG VERSION

# ── Stage 1: Extract jemalloc library ──
FROM public.ecr.aws/amazoncorretto/amazoncorretto:${VERSION} AS builder

RUN yum install -y jemalloc

# ── Stage 2: Final runtime image ──
FROM public.ecr.aws/amazoncorretto/amazoncorretto:${VERSION}

COPY --from=builder /usr/lib64/libjemalloc.so.2 /usr/lib64/libjemalloc.so.2

ADD wait-for-it.sh /usr/local/bin/

RUN yum update -y && \
    yum install -y tar gzip procps which && \
    yum clean all && \
    rm -rf /var/cache/yum /tmp/*

ENV LD_PRELOAD=/usr/lib64/libjemalloc.so.2
