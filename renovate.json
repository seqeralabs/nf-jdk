{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended"
  ],

  "customManagers": [
    {
      "customType": "regex",
      "description": "Track container image digests in Make file",
      "fileMatch": ["^Make$", "Makefile"],
      "matchStrings": [
        "[A-Z_0-9-]+\\s*=\\s*(?<depName>[^\\s:]+):(?<currentValue>[^@]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "description": "Do not bump to a new major JDK version automatically",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Group all Makefile Docker digest updates into a single PR to avoid merge conflicts",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["^Make$", "Makefile"],
      "groupName": "Makefile Docker digests"
    }
  ]
}
